# ====================================================================
# Telegram LLM bot — environment configuration
# Copy this file to `.env` and fill in the values, or set these as
# Railway service variables. Nothing here is persisted by the bot itself.
# ====================================================================

# --- Required secrets ---------------------------------------------------
# Token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token
# Single OpenRouter API key used for chat, vision AND transcription.
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# --- OpenRouter endpoint ------------------------------------------------
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Model slugs --------------------------------------------------------
# IMPORTANT: confirm the exact current slugs at https://openrouter.ai/models
# before deploying — model names change over time. The values below were the
# current matches as of 2026-06 for the intended models:
#   MODEL_TEXT      -> DeepSeek "flash"-tier chat model
#   MODEL_VISION    -> Google Gemini Flash (photos/OCR; good text fallback too)
#   MODEL_TRANSCRIBE-> OpenAI Whisper Large v3 (99+ languages incl. ru/uk)
#   MODEL_IMAGE     -> Google Gemini image model (used by 🎨 Image)
MODEL_TEXT=deepseek/deepseek-v3.2
MODEL_VISION=google/gemini-3.5-flash
MODEL_TRANSCRIBE=openai/whisper-large-v3
MODEL_IMAGE=google/gemini-2.5-flash-image

# OpenRouter attribution headers (shown on your OpenRouter dashboard/rankings).
OPENROUTER_APP_TITLE=Telegram LLM Bot
OPENROUTER_APP_REFERER=https://t.me

# --- Behaviour tuning ---------------------------------------------------
# Seconds of silence after the last message before a batch is finalized.
DEBOUNCE_SECONDS=2.5
# Max messages collected into a single batch (extras are dropped with a note).
MAX_BATCH_MESSAGES=50
# Max characters of context sent to the LLM (oldest items truncated first).
MAX_CONTEXT_CHARS=60000
# Max characters kept from any single fetched link or parsed context file.
CONTEXT_MAX_CHARS=20000

# --- Guardrails (public bot on a paid API) ------------------------------
MAX_BATCHES_PER_HOUR=10
MAX_LLM_CALLS_PER_DAY=50
# Comma-separated Telegram user IDs allowed to use the bot.
# Leave EMPTY for a public bot (everyone allowed). Example: 11111111,22222222
ALLOWED_USER_IDS=

# --- Link fetching ------------------------------------------------------
# Timeout (seconds) when fetching a link attached as custom-prompt context.
LINK_FETCH_TIMEOUT=15

# --- Logging ------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
