# ====================================================================
# Telegram LLM bot — environment configuration
# Copy this file to `.env` and fill in the values, or set these as
# Railway service variables. Nothing here is persisted by the bot itself.
# ====================================================================

# --- Required secrets ---------------------------------------------------
# Token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token
# Single OpenRouter API key used for chat, vision AND transcription.
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# --- OpenRouter endpoint ------------------------------------------------
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Model slugs --------------------------------------------------------
# IMPORTANT: confirm the exact current slugs at https://openrouter.ai/models
# before deploying — model names change over time. The values below were the
# current matches as of 2026-06 for the intended models:
#   MODEL_TEXT      -> DeepSeek "flash"-tier chat model
#   MODEL_VISION    -> Google Gemini Flash (photos/OCR; good text fallback too)
#   MODEL_TRANSCRIBE-> OpenAI Whisper Large v3 (99+ languages incl. ru/uk)
MODEL_TEXT=deepseek/deepseek-v3.2
MODEL_VISION=google/gemini-3.5-flash
MODEL_TRANSCRIBE=openai/whisper-large-v3
# Image generation is disabled (FEATURE_IMAGE=false); set this only if re-enabling.
MODEL_IMAGE=

# OpenRouter attribution headers (shown on your OpenRouter dashboard/rankings).
OPENROUTER_APP_TITLE=Telegram LLM Bot
OPENROUTER_APP_REFERER=https://t.me

# --- Behaviour tuning ---------------------------------------------------
# Seconds of silence after the last message before a batch is finalized.
DEBOUNCE_SECONDS=2.5
# Max messages collected into a single batch (extras are dropped with a note).
MAX_BATCH_MESSAGES=50
# Max characters of context sent to the LLM (oldest items truncated first).
MAX_CONTEXT_CHARS=60000
# Max characters kept from any single fetched link or parsed context file.
CONTEXT_MAX_CHARS=20000

# --- Guardrails (public bot on a paid API) ------------------------------
# Coarse anti-spam cap on finalized batches per hour (per user). The real
# per-day usage limits live in the "Free/Pro tier quotas" sections below.
MAX_BATCHES_PER_HOUR=10
# Comma-separated Telegram user IDs allowed to use the bot.
# Leave EMPTY for a public bot (everyone allowed). Example: 11111111,22222222
ALLOWED_USER_IDS=

# --- Link fetching ------------------------------------------------------
# Timeout (seconds) when fetching a link attached as custom-prompt context.
LINK_FETCH_TIMEOUT=15

# --- Output rendering & streaming --------------------------------------
# Answers are delivered as clean plain text by default (markdown stripped,
# split into several messages when long). A formatted message / .md file is
# produced only when the user explicitly asks ("markdown", "as a file", …).
# Stream the answer live as it's generated (sendMessageDraft, with an
# edit-message fallback). false -> wait for the full answer, then send it.
STREAMING_ENABLED=true
# Minimum ms between live draft/edit updates while streaming (Telegram throttle).
STREAM_THROTTLE_MS=1000

# --- Logging ------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# ====================================================================
# Monetization & persistence layer
# ====================================================================

# --- Persistence --------------------------------------------------------
# Railway Postgres plugin injects this automatically (postgresql://...).
# Required for quotas / Pro / saved keys / payments to work.
DATABASE_URL=
# Fernet key (urlsafe base64, 32 bytes) for encrypting bring-your-own keys.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET=

# --- Pro tier model / context ------------------------------------------
# Pro text model (confirm slug at https://openrouter.ai/models). Empty -> MODEL_TEXT.
MODEL_TEXT_PRO=
MAX_CONTEXT_CHARS_PRO=120000

# --- Feature flags (disabled features keep their code, just unwired) -----
FEATURE_PPTX=false
FEATURE_PDF=false
FEATURE_IMAGE=false

# --- Billing (Telegram Stars only; 1 ⭐ = 1 credit) ---------------------
# Stars price (XTR) for a 30-day Pro subscription. (TEST: 1; use 250 for real.)
PRO_PRICE_STARS=1
PRO_PERIOD_DAYS=30
# Credits granted each Pro cycle (2× the Stars price = obvious value).
PRO_MONTHLY_CREDITS=500
# Pro discount on extra-credit packs (0.30 = 30% off).
PRO_CREDIT_DISCOUNT=0.30
# Buyable pack sizes (credits = Stars before any Pro discount).
# (TEST: includes a 1-credit pack; drop the leading 1 for real pricing.)
CREDIT_PACKS=1,100,500,1000
# Anti-fraud: max Pro grants per user per day (excess is held for admin review).
MAX_PRO_PURCHASES_PER_DAY=3
# Telegram user id that receives payment notifications (0 = disabled).
ADMIN_USER_ID=0

# --- Credits (values in CREDITS; stored/charged internally as tenths) ----
# Text is charged by input+output tokens: ~1 credit per this many tokens (min 0.1).
TEXT_TOKENS_PER_CREDIT=20000
# Audio: credits per minute (charged by real duration, not rounded to whole).
CREDITS_AUDIO_PER_MIN=1
# Photo analysis: credits per analyzed photo.
CREDITS_PHOTO=0.5
# Image generation cost (defined for when FEATURE_IMAGE is re-enabled; inactive now).
CREDITS_IMAGE=0.5
# One-time signup bonus (to persistent credits) on first /start.
SIGNUP_BONUS_CREDITS=60
# Daily free floor for non-Pro users (reset each day, never accumulates). 0 = off.
DAILY_FREE_CREDITS=12
# Referral bonus to BOTH parties on a valid referral (one-time).
REFERRAL_BONUS_CREDITS=50
# Saved-prompt cap for non-Pro/non-BYO users.
FREE_SAVED_PROMPTS=3

# --- Presentations deck config (inactive while FEATURE_PPTX=false) ------
MODEL_DECK=
MODEL_QA_VISION=
DECK_QA_ENABLED=true
DECK_QA_MAX_PASSES=1
DECK_QA_MAX_SLIDES=15

# --- Group mode (in-memory thread buffer; nothing stored in Postgres) ---
GROUP_BUFFER_MAX=300
GROUP_BUFFER_TTL_HOURS=24
GROUP_SUMMARY_DEFAULT=50
GROUP_WINDOW_FREE=80
GROUP_WINDOW_PRO=400
GROUP_COOLDOWN_SEC=30
